# ── Supabase ─────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service role key — SOLO en el servidor. Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── WhatsApp ─────────────────────────────────────────────
# Número en formato internacional sin "+" ni espacios. Ej: 573001234567
NEXT_PUBLIC_WHATSAPP_NUMBER=573122286131

# ── Tienda ───────────────────────────────────────────────
NEXT_PUBLIC_STORE_NAME=FrikiLoot
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Umbral de stock bajo para alertas/notificaciones
NEXT_PUBLIC_LOW_STOCK_THRESHOLD=5

# ── Google Analytics 4 ───────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
